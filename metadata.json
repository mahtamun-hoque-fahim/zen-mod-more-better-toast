{
  "name": "Better Toast",
  "description": "Frosted-glass pill toast notifications with dark/light auto-color, backdrop blur, and full position control.",
  "id": "mahtamun-better-toast@zen",
  "author": "mahtamun-hoque-fahim",
  "version": "1.0.0",
  "tags": ["toast", "notification", "glass", "blur", "minimal"],
  "homepage": "https://github.com/mahtamun-hoque-fahim/zen-mod-more-better-toast",
  "preferences": [
    {
      "property": "mbt-position-v",
      "label": "Vertical Position",
      "type": "dropdown",
      "options": [
        { "label": "Top",    "value": "top"    },
        { "label": "Bottom", "value": "bottom" }
      ],
      "default": "top"
    },
    {
      "property": "mbt-position-h",
      "label": "Horizontal Position",
      "type": "dropdown",
      "options": [
        { "label": "Auto (sidebar-aware)", "value": "auto"   },
        { "label": "Left",                 "value": "left"   },
        { "label": "Center",               "value": "center" },
        { "label": "Right",                "value": "right"  }
      ],
      "default": "auto"
    }
  ]
}
